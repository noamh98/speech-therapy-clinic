rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ── Helpers ────────────────────────────────────────────────────────────────

    function isAuth() {
      return request.auth != null;
    }

    function isAdmin() {
      // Role stored in DB — not email — so it can't be spoofed by changing email
      return isAuth()
        && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    // Read / update / delete: the document's ownerId must equal the caller's uid
    function canAccessRecord() {
      return isAuth() && (
        resource.data.ownerId == request.auth.uid
        || isAdmin()
      );
    }

    // Create: the incoming document's ownerId must equal the caller's uid
    function canCreateRecord() {
      return isAuth() && (
        request.resource.data.ownerId == request.auth.uid
        || isAdmin()
      );
    }

    // Update: caller must own the existing doc AND must not change ownerId
    function canUpdateRecord() {
      return canAccessRecord()
        && request.resource.data.ownerId == resource.data.ownerId;
    }

    // ── Users ──────────────────────────────────────────────────────────────────
    match /users/{userId} {
      allow read:   if isAuth() && (request.auth.uid == userId || isAdmin());
      allow create: if isAuth() && request.auth.uid == userId;
      allow update: if isAuth() && request.auth.uid == userId;
      allow delete: if isAdmin();
    }

    // ── Clinic data collections ────────────────────────────────────────────────
    match /patients/{id} {
      allow read:   if canAccessRecord();
      allow create: if canCreateRecord();
      allow update: if canUpdateRecord();
      allow delete: if canAccessRecord();
    }

    match /appointments/{id} {
      allow read:   if canAccessRecord();
      allow create: if canCreateRecord();
      allow update: if canUpdateRecord();
      allow delete: if canAccessRecord();
    }

    match /treatments/{id} {
      allow read:   if canAccessRecord();
      allow create: if canCreateRecord();
      allow update: if canUpdateRecord();
      allow delete: if canAccessRecord();
    }

    match /payments/{id} {
      allow read:   if canAccessRecord();
      allow create: if canCreateRecord();
      allow update: if canUpdateRecord();
      allow delete: if canAccessRecord();
    }

    match /progress/{id} {
      allow read:   if canAccessRecord();
      allow create: if canCreateRecord();
      allow update: if canUpdateRecord();
      allow delete: if canAccessRecord();
    }

    match /intakeForms/{id} {
      allow read:   if canAccessRecord();
      allow create: if canCreateRecord();
      allow update: if canUpdateRecord();
      allow delete: if canAccessRecord();
    }

    match /templates/{id} {
      allow read:   if canAccessRecord();
      allow create: if canCreateRecord();
      allow update: if canUpdateRecord();
      allow delete: if canAccessRecord();
    }

    match /notifications/{id} {
      allow read:   if canAccessRecord();
      allow create: if canCreateRecord();
      allow update: if canUpdateRecord();
      allow delete: if canAccessRecord();
    }

    // ── Storage metadata (receipts) ────────────────────────────────────────────
    match /receipts/{userId}/{allPaths=**} {
      allow read:  if isAuth() && (request.auth.uid == userId || isAdmin());
      allow write: if isAuth() && request.auth.uid == userId;
    }
  }
}
